{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    "default:pinDigestsDisabled"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* 0 1 * *"]
  },
  "timezone": "Etc/UTC",
  "schedule": ["* 0 1 * *"],
  "enabledManagers": ["nix", "github-actions", "cargo"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "prCreation": "immediate",
  "automerge": false,
  "platformAutomerge": true,
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions", "nix"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "automerge": true
    },
    {
      "groupName": "egui + windowing stack",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "egui",
        "egui_glow",
        "egui-winit",
        "glow",
        "glutin",
        "glutin-winit",
        "winit",
        "raw-window-handle"
      ],
      "description": "The chrome-caching work relies on undocumented internal behaviour of the egui 0.35.0 stack; egui/egui_glow/egui-winit are exact-pinned. Never auto-merge these, and require explicit Dependency-Dashboard approval before a bump PR is even opened, so a human consciously runs the Documents/EGUI_UPGRADE_ASSUMPTIONS.md re-verification checklist first.",
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "groupName": "tracing",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "tracing",
        "tracing-appender",
        "tracing-log",
        "tracing-subscriber",
        "tracing-core",
        "tracing-tree"
      ]
    },
    {
      "groupName": "serde",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "serde",
        "serde_repr",
        "serde_derive",
        "serde_json",
        "serde_with",
        "rmp-serde"
      ]
    },
    {
      "groupName": "font shaping stack",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["rustybuzz", "swash", "fontdb", "ttf-parser"]
    },
    {
      "groupName": "clap",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["clap", "clap-cargo", "clap-verbosity-flag"]
    },
    {
      "groupName": "error handling",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["anyhow", "thiserror", "color-eyre"]
    },
    {
      "groupName": "unicode",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["unicode-segmentation", "unicode-width"]
    },
    {
      "groupName": "windows platform apis",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["winapi", "winreg", "shared_library"]
    },
    {
      "groupName": "rust test tooling",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "assert_cmd",
        "predicates",
        "proptest",
        "test-log",
        "tempfile"
      ]
    }
  ]
}
